@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,700&family=Inter:wght@300;400;500;600&family=Outfit:wght@300;400;500;600;700&display=swap');
:root{
  --green:#1a6b3c;--green-light:#2ecc71;--gold:#c9a84c;--saffron:#e8a020;--saffron-light:#f5c430;
  --bg:#fffdf8;--bg2:#f6f0e4;--bg3:#f0e8d5;--card:#ffffff;--dark:#1a1208;--dark2:#120d06;
  --text:#1a1208;--text-muted:#7a6652;--border:rgba(201,168,76,.18);
  --heading:'Cormorant Garamond',serif;--body:'Inter',sans-serif;--accent:'Outfit',sans-serif;
  --shadow:0 4px 24px rgba(26,18,8,.08);--shadow-lg:0 12px 50px rgba(26,18,8,.14)
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:var(--body);background:var(--bg);color:var(--text);overflow-x:hidden;line-height:1.7}
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-track{background:var(--bg2)}::-webkit-scrollbar-thumb{background:var(--saffron);border-radius:3px}

/* Skip link for accessibility */
.skip-link {
  position: absolute;
  top: -40px;
  left: 0;
  background: var(--saffron);
  color: white;
  padding: 8px 16px;
  z-index: 1000;
  transition: top 0.3s;
  font-family: var(--accent);
  font-size: 0.875rem;
  border-radius: 0 0 8px 8px;
}

.skip-link:focus {
  top: 0;
}

/* Language button feedback */
.lang-btn {
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.lang-btn:active {
  transform: scale(0.95);
}

.lang-btn::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  transform: translate(-50%, -50%);
  transition: width 0.3s ease, height 0.3s ease;
}

.lang-btn:active::after {
  width: 100px;
  height: 100px;
}

/* Make Reserve button more prominent */
.nav-cta {
  position: relative;
  overflow: hidden;
  font-weight: 700;
  box-shadow: 0 4px 15px rgba(26, 18, 8, 0.2);
}

.nav-cta:hover {
  box-shadow: 0 6px 20px rgba(26, 18, 8, 0.3);
  transform: translateY(-2px);
}

.nav-cta:active {
  transform: translateY(0);
}

/* Marquee accessibility controls */
.marquee {
  position: relative;
}

.marquee-controls {
  position: absolute;
  bottom: 10px;
  right: 15px;
  display: flex;
  gap: 8px;
  z-index: 10;
}

.marquee-btn {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.2);
  color: var(--saffron);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.3s ease;
  font-size: 0.875rem;
}

.marquee-btn:hover {
  background: rgba(255,255,255,0.2);
  transform: scale(1.1);
}

.marquee-btn:active {
  transform: scale(0.9);
}

/* ─── TOP BAR ─── */
.top-bar{background:linear-gradient(90deg,#1a0e02 0%,#2a1a04 50%,#1a0e02 100%);border-bottom:2px solid rgba(232,160,32,.35);padding:.6rem 4%;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:200;height:48px}
.top-bar-left{display:flex;align-items:center;gap:1.8rem}
.top-hours,.top-phone{font-family:var(--accent);font-size:.75rem;color:rgba(255,255,255,.7);letter-spacing:1.5px;text-decoration:none;display:flex;align-items:center;gap:8px;transition:.3s}
.top-hours i{color:var(--saffron)}.top-phone i{color:var(--saffron)}
.top-phone:hover{color:var(--saffron-light)}
.top-bar-right{display:flex;align-items:center;gap:5px}
.tsoc{width:38px;height:38px;border-radius:10px;background:rgba(255,255,255,.07);display:flex;align-items:center;justify-content:center;text-decoration:none;color:rgba(255,255,255,.6);font-size:1.1rem;transition:.3s;border:1px solid rgba(255,255,255,.08)}
.tsoc:hover{transform:translateY(-2px);background:rgba(255,255,255,.14);border-color:rgba(255,255,255,.2)}
/* Original social brand colors */
.tsoc.ig:hover{color:#E1306C;border-color:#E1306C;background:rgba(225,48,108,.12)}
.tsoc.fb:hover{color:#1877F2;border-color:#1877F2;background:rgba(24,119,242,.12)}
.tsoc.tg:hover{color:#29A9EB;border-color:#29A9EB;background:rgba(41,169,235,.12)}
.tsoc.tt:hover{color:#fff;border-color:#fff;background:#000}
.tsoc.wa:hover{color:#25D366;border-color:#25D366;background:rgba(37,211,102,.12)}
.tsoc.yt:hover{color:#FF0000;border-color:#FF0000;background:rgba(255,0,0,.12)}
/* Default brand colors (visible without hover) */
.tsoc.ig{color:#E1306C}.tsoc.fb{color:#1877F2}.tsoc.tg{color:#29A9EB}
.tsoc.tt{color:#fff}.tsoc.wa{color:#25D366}.tsoc.yt{color:#FF0000}
.tsoc-delivery{width:auto;padding:0 14px;font-family:var(--accent);font-size:.7rem;font-weight:600;letter-spacing:1px;color:rgba(255,255,255,.7)!important}
.tsoc-delivery.glovo{color:#FFC244!important;border-color:rgba(255,194,68,.3)!important}
.tsoc-delivery.wolt{color:#009de0!important;border-color:rgba(0,157,224,.3)!important}
.tsoc-delivery.bolt{color:#34D186!important;border-color:rgba(52,209,134,.3)!important}

/* ─── NAV ─── */
.nav{position:sticky;top:48px;width:100%;z-index:100;padding:1rem 4%;display:flex;align-items:center;justify-content:space-between;background:rgba(255,253,248,.96);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid var(--border);transition:.4s;will-change:padding,box-shadow}
.nav.scrolled{padding:.7rem 4%;box-shadow:var(--shadow)}
.page-hero,.marquee{margin-top:0}
.nav-logo{text-decoration:none}
.nav-brand{font-family:var(--accent);font-size:1.15rem;font-weight:700;color:var(--dark);letter-spacing:3px}
.nav-brand em{color:var(--saffron);font-style:normal}
.nav-center{display:flex;gap:2rem;list-style:none}
.nav-center a{text-decoration:none;color:var(--text-muted);font-size:.78rem;font-weight:500;letter-spacing:2px;text-transform:uppercase;transition:color .3s;font-family:var(--accent);position:relative}
.nav-center a:hover,.nav-center a.active{color:var(--saffron)}
.nav-center a::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:2px;background:var(--saffron);border-radius:2px;transition:width .3s}
.nav-center a:hover::after{width:100%}
.nav-right{display:flex;align-items:center;gap:.8rem}
.lang-toggle{display:flex;gap:2px;background:var(--bg2);border-radius:20px;padding:3px;border:1px solid var(--border)}
.lang-btn{padding:5px 12px;border-radius:16px;border:none;background:transparent;color:var(--text-muted);font-size:.65rem;font-weight:600;cursor:pointer;transition:.3s;font-family:var(--accent);letter-spacing:1px}
.lang-btn.active{background:var(--saffron);color:#fff}
.nav-cta{padding:9px 24px;border-radius:30px;background:var(--green);color:#fff;text-decoration:none;font-size:.68rem;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;transition:.3s;font-family:var(--accent);border:2px solid var(--green)}
.nav-cta:hover{background:transparent;color:var(--green);border-color:var(--green)}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:4px}
.hamburger span{display:block;width:26px;height:2px;background:var(--dark);transition:.3s;border-radius:2px}
.hamburger.active span:nth-child(1){transform:rotate(45deg) translate(5px,5px)}
.hamburger.active span:nth-child(2){opacity:0}
.hamburger.active span:nth-child(3){transform:rotate(-45deg) translate(5px,-5px)}
.mobile-nav{display:none;position:fixed;inset:0;background:rgba(255,253,248,.98);backdrop-filter:blur(30px);-webkit-backdrop-filter:blur(30px);z-index:999;flex-direction:column;justify-content:center;align-items:center;transform:translateX(100%);transition:transform .5s cubic-bezier(.16,1,.3,1)}
.mobile-nav.open{transform:translateX(0)}
.mobile-nav a{font-family:var(--heading);font-size:2.2rem;color:var(--dark);text-decoration:none;padding:.5rem;display:block;transition:.3s;font-weight:600}
.mobile-nav a:hover{color:var(--saffron)}
.mobile-lang{display:flex;gap:8px;margin-top:2rem}
.mobile-lang .lang-btn{padding:10px 22px;font-size:.85rem}

/* ─── HERO — BRIGHTER VIDEO ─── */
.hero{position:relative;height:100vh;min-height:700px;display:flex;align-items:flex-end;padding-bottom:7rem}
.hero-video-wrap{position:absolute;inset:0;will-change:transform;overflow:hidden}
.hero-video{width:100%;height:100%;object-fit:cover;filter:brightness(.55) saturate(1.15)}
.hero-overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(26,18,8,.5) 0%,rgba(26,18,8,.1) 30%,transparent 50%,rgba(26,18,8,.45) 70%,rgba(26,18,8,.92) 100%)}
.hero-content{position:relative;z-index:2;padding:0 6%;max-width:950px;width:100%}
.hero-label{font-family:var(--accent);font-size:.75rem;letter-spacing:4px;text-transform:uppercase;color:var(--saffron);margin-bottom:1.4rem;display:block;opacity:0;animation:fadeUp .8s .2s forwards}
.hero h1{font-family:var(--heading);font-size:clamp(4rem,8vw,7.5rem);font-weight:700;line-height:.96;letter-spacing:-2px;margin-bottom:1.8rem;opacity:0;animation:fadeUp .8s .4s forwards;color:#fff}
.hero h1 .green{color:var(--green-light)}.hero h1 .gold{color:var(--saffron-light)}
.hero-desc{font-size:clamp(1.05rem,1.5vw,1.2rem);color:rgba(255,255,255,.88);font-weight:400;max-width:580px;margin-bottom:3rem;line-height:1.85;opacity:0;animation:fadeUp .8s .6s forwards}
.hero-actions{display:flex;gap:1rem;flex-wrap:wrap;opacity:0;animation:fadeUp .8s .9s forwards}
.btn-main{padding:14px 38px;border-radius:50px;background:var(--saffron);color:#fff;text-decoration:none;font-size:.78rem;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;transition:.3s;border:2px solid var(--saffron);font-family:var(--accent);display:inline-flex;align-items:center;gap:8px}
.btn-main:hover{background:transparent;color:var(--saffron);box-shadow:0 0 30px rgba(232,160,32,.2)}
.btn-ghost{padding:14px 38px;border-radius:50px;background:transparent;color:#fff;text-decoration:none;font-size:.78rem;font-weight:500;letter-spacing:1.5px;text-transform:uppercase;border:1px solid rgba(255,255,255,.3);transition:.3s;font-family:var(--accent)}
.btn-ghost:hover{border-color:var(--saffron);color:var(--saffron)}
.hero-scroll{position:absolute;bottom:2.5rem;left:50%;transform:translateX(-50%);z-index:2;display:flex;flex-direction:column;align-items:center;gap:6px;opacity:0;animation:fadeIn 1s 1.5s forwards}
.hero-scroll span{font-family:var(--accent);font-size:.58rem;letter-spacing:4px;text-transform:uppercase;color:rgba(255,255,255,.5)}
.hero-scroll-line{width:1px;height:32px;background:linear-gradient(180deg,var(--saffron),transparent);animation:pulse 2s infinite}

/* ─── MARQUEE ─── */
.marquee{overflow:hidden;padding:1.2rem 0;background:var(--dark);border-top:2px solid rgba(232,160,32,.2);border-bottom:2px solid rgba(232,160,32,.2)}
.marquee-track{display:flex;gap:2.5rem;animation:scroll 28s linear infinite;width:max-content;will-change:transform}
.marquee-item{white-space:nowrap;font-family:var(--heading);font-size:1.05rem;color:rgba(255,255,255,.45);display:flex;align-items:center;gap:.8rem}
.marquee-item .dot{width:5px;height:5px;border-radius:50%;background:var(--saffron)}

/* ─── SECTIONS ─── */
section{padding:6rem 2rem;contain:layout style}
section:nth-of-type(even){background:var(--bg2)}
.container{max-width:1140px;margin:0 auto}
.section-label{font-family:var(--accent);font-size:.78rem;letter-spacing:4px;text-transform:uppercase;color:var(--saffron);margin-bottom:.6rem;display:block}
.section-title{font-family:var(--heading);font-size:clamp(2.4rem,5vw,3.8rem);font-weight:700;line-height:1.08;color:var(--dark);margin-bottom:.8rem}
.section-sub{color:var(--text-muted);font-size:1rem;max-width:520px;font-weight:400;line-height:1.8}

/* ─── ABOUT ─── */
.about-grid{display:grid;grid-template-columns:1fr 1.1fr;gap:5rem;align-items:center;margin-top:3rem}
.about-img{border-radius:20px;overflow:hidden;aspect-ratio:4/5;box-shadow:var(--shadow-lg)}
.about-img img{width:100%;height:100%;object-fit:cover;transition:transform .6s}
.about-img:hover img{transform:scale(1.03)}
.about-body p{color:var(--text-muted);font-size:1rem;line-height:1.9;margin-bottom:1.5rem;font-weight:400}
.about-body blockquote{font-family:var(--heading);font-size:1.5rem;font-style:italic;color:var(--saffron);line-height:1.6;margin:2rem 0;padding-left:1.5rem;border-left:3px solid var(--saffron)}
.values{list-style:none;display:grid;grid-template-columns:1fr 1fr;gap:.7rem;margin:1.5rem 0}
.values li{display:flex;align-items:center;gap:10px;font-size:.95rem;color:var(--text-muted);font-weight:400}
.check{width:22px;height:22px;min-width:22px;border-radius:50%;background:rgba(232,160,32,.1);color:var(--saffron);display:flex;align-items:center;justify-content:center;font-size:.65rem;border:1px solid rgba(232,160,32,.25)}

/* ─── OWNER ─── */
.owner-section{background:var(--bg2);padding:4rem 2rem}
.owner-card{max-width:800px;margin:0 auto;display:flex;align-items:center;gap:3rem;background:var(--card);border:1px solid var(--border);border-radius:24px;padding:3rem;box-shadow:var(--shadow)}
.owner-photo{flex-shrink:0}
.owner-initials{width:100px;height:100px;border-radius:50%;background:linear-gradient(135deg,var(--saffron),var(--gold));display:flex;align-items:center;justify-content:center;font-family:var(--heading);font-size:2.2rem;font-weight:700;color:#fff}
.owner-info .section-label{margin-bottom:.3rem}
.owner-info h3{font-family:var(--heading);font-size:2.2rem;font-weight:700;color:var(--dark);margin-bottom:.8rem}
.owner-info p{color:var(--text-muted);font-size:.88rem;line-height:1.8;margin-bottom:1.2rem}
.owner-linkedin{display:inline-flex;align-items:center;gap:8px;padding:11px 26px;border-radius:30px;background:rgba(10,102,194,.08);color:#0a66c2;text-decoration:none;font-size:.78rem;font-weight:600;letter-spacing:1px;border:1px solid rgba(10,102,194,.2);transition:.3s;font-family:var(--accent)}
.owner-linkedin:hover{background:rgba(10,102,194,.15);transform:translateY(-2px)}

/* ─── MISSION (NEW) ─── */
.mission-section{background:var(--bg);padding:6rem 2rem;position:relative;overflow:hidden}
.mission-section::before{content:'';position:absolute;top:-80px;right:-80px;width:300px;height:300px;border-radius:50%;background:radial-gradient(circle,rgba(74,140,60,.06) 0%,transparent 70%);pointer-events:none}
.mission-section::after{content:'';position:absolute;bottom:-80px;left:-80px;width:250px;height:250px;border-radius:50%;background:radial-gradient(circle,rgba(232,160,32,.05) 0%,transparent 70%);pointer-events:none}
.mission-inner{max-width:820px;margin:0 auto;text-align:center;position:relative;z-index:1}
.mission-icon{font-size:3rem;margin-bottom:1.5rem;display:block}
.mission-inner .section-title{margin-bottom:1.5rem}
.mission-text{font-size:1.08rem;color:var(--text-muted);line-height:2;font-weight:300;max-width:680px;margin:0 auto 2.5rem}
.mission-pillars{display:flex;gap:2rem;justify-content:center;flex-wrap:wrap}
.mission-pillar{display:flex;align-items:center;gap:10px;padding:12px 24px;background:var(--card);border:1px solid var(--border);border-radius:50px;font-family:var(--accent);font-size:.8rem;font-weight:500;color:var(--text);box-shadow:var(--shadow);transition:.3s;letter-spacing:.5px}
.mission-pillar:hover{transform:translateY(-3px);box-shadow:var(--shadow-lg);border-color:rgba(232,160,32,.3)}
.mission-pillar i{color:var(--saffron);font-size:1rem}

/* ─── PHOTO BREAK ─── */
.photo-break{position:relative;height:60vh;min-height:420px;overflow:hidden;display:flex;align-items:center;justify-content:center}
.photo-break img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;filter:brightness(.42);transition:transform 8s ease;will-change:transform}
.photo-break:hover img{transform:scale(1.04)}
.photo-break-overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(26,18,8,.3) 0%,transparent 18%,transparent 82%,rgba(26,18,8,.3) 100%)}
.photo-break-text{position:relative;z-index:2;text-align:center;max-width:760px;padding:0 2rem}
.photo-break-text blockquote{font-family:var(--heading);font-size:clamp(1.8rem,3.8vw,3rem);font-style:italic;color:#fff;line-height:1.4;font-weight:600;text-shadow:0 2px 20px rgba(0,0,0,.4)}
.photo-break-text cite{display:block;margin-top:1.2rem;font-family:var(--accent);font-size:.78rem;letter-spacing:3px;text-transform:uppercase;color:var(--saffron);font-style:normal}

/* ─── MENU ─── */
.menu-tabs{display:flex;gap:.5rem;flex-wrap:wrap;margin:2.5rem 0 2rem;border-bottom:2px solid var(--border);padding-bottom:1rem}
.tab-btn{padding:9px 22px;border-radius:30px;border:1px solid var(--border);background:var(--card);color:var(--text-muted);font-size:.8rem;font-weight:500;letter-spacing:1.5px;text-transform:uppercase;cursor:pointer;transition:.3s;font-family:var(--accent)}
.tab-btn:hover{border-color:var(--saffron);color:var(--saffron)}
.tab-btn.active{background:var(--saffron);border-color:var(--saffron);color:#fff}
.menu-panel{display:none}.menu-panel.active{display:block}
.menu-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem}
.menu-card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:1.4rem;display:flex;justify-content:space-between;align-items:flex-start;gap:1rem;transition:.3s;box-shadow:var(--shadow)}
.menu-card:hover{transform:translateY(-3px);box-shadow:var(--shadow-lg);border-color:rgba(232,160,32,.3)}
.menu-card-body h4{font-family:var(--heading);font-size:1.1rem;font-weight:600;color:var(--dark);margin-bottom:.3rem}
.mc-desc{font-size:.85rem;color:var(--text-muted);line-height:1.6}
.mc-price{font-family:var(--accent);font-size:.9rem;font-weight:700;color:var(--saffron);white-space:nowrap}
.tag-v{font-size:.65rem;padding:3px 8px;border-radius:8px;vertical-align:middle;font-family:var(--accent);margin-left:5px;background:rgba(46,204,113,.1);color:var(--green);border:1px solid rgba(46,204,113,.2)}
.tag-vg{font-size:.65rem;padding:3px 8px;border-radius:8px;vertical-align:middle;font-family:var(--accent);margin-left:5px;background:rgba(201,168,76,.1);color:#9a7a20;border:1px solid rgba(201,168,76,.2)}
.menu-cta{text-align:center;padding:3rem 2rem;background:var(--bg2);border-radius:24px;border:1px solid var(--border);max-width:600px;margin:3rem auto 0;box-shadow:var(--shadow)}
.menu-cta p{color:var(--text-muted);font-size:.9rem;margin-bottom:2rem;line-height:1.8}

/* ─── CONTACT ─── */
.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:3rem;margin-top:3rem}
.contact-cards{display:flex;flex-direction:column;gap:.8rem}
.c-card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:1.4rem;display:flex;align-items:flex-start;gap:1rem;transition:.3s;box-shadow:var(--shadow)}
.c-card:hover{transform:translateY(-2px);box-shadow:var(--shadow-lg)}
.c-icon{width:42px;height:42px;min-width:42px;border-radius:12px;background:rgba(232,160,32,.1);display:flex;align-items:center;justify-content:center;color:var(--saffron);font-size:1.05rem}
.c-card h4{font-family:var(--accent);font-size:.75rem;text-transform:uppercase;letter-spacing:2px;color:var(--text-muted);margin-bottom:3px}
.c-card p{font-size:.88rem;color:var(--text)}
.c-card a{color:var(--green);text-decoration:none}.c-card a:hover{color:var(--saffron)}
.c-note{font-size:.75rem;color:var(--text-muted);margin-top:3px}
.delivery-links{display:flex;gap:.6rem;margin-top:.6rem;flex-wrap:wrap}
.delivery-pill{display:inline-flex;align-items:center;gap:6px;padding:9px 22px;border-radius:30px;text-decoration:none;font-family:var(--accent);font-size:.76rem;font-weight:600;letter-spacing:.5px;transition:.3s}
.glovo-pill{background:rgba(255,149,0,.1);color:#e68a00;border:2px solid rgba(255,149,0,.25)}
.glovo-pill:hover{background:rgba(255,149,0,.18);transform:translateY(-2px)}
.wolt-pill{background:rgba(0,157,224,.1);color:#009de0;border:2px solid rgba(0,157,224,.25)}
.wolt-pill:hover{background:rgba(0,157,224,.18);transform:translateY(-2px)}
.map-wrap{border-radius:20px;overflow:hidden;height:100%;min-height:420px;border:2px solid var(--border);box-shadow:var(--shadow)}
.map-wrap iframe{width:100%;height:100%;border:none}

/* ─── GALLERY PAGE ─── */
.page-hero{background:var(--dark);padding:8rem 4% 5rem;text-align:center}
.page-hero .section-label{color:var(--saffron)}
.page-hero .section-title{color:#fff}
.page-hero .section-sub{color:rgba(255,255,255,.6);margin:0 auto}
.gallery-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;padding:8px}
.gi{overflow:hidden;border-radius:10px;cursor:zoom-in;position:relative}
.gi img{width:100%;height:100%;display:block;transition:transform .5s ease;aspect-ratio:4/3;object-fit:cover}
.gi:hover img{transform:scale(1.05)}

/* Gallery lightbox */
.lightbox{position:fixed;inset:0;background:rgba(0,0,0,.92);z-index:2000;display:none;align-items:center;justify-content:center;cursor:zoom-out;backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px)}
.lightbox.active{display:flex}
.lightbox img{max-width:90vw;max-height:90vh;border-radius:12px;box-shadow:0 20px 80px rgba(0,0,0,.5);object-fit:contain}
.lightbox-close{position:absolute;top:24px;right:32px;font-size:2rem;color:#fff;cursor:pointer;opacity:.7;transition:.3s;background:none;border:none;font-family:var(--accent)}
.lightbox-close:hover{opacity:1;transform:scale(1.1)}

/* ─── HOTEL PAGE ─── */
.hotel-grid{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:start;margin-top:3rem}
.hotel-gallery-wrap{display:flex;flex-direction:column;gap:.6rem}
.hotel-img-main{width:100%;border-radius:20px;aspect-ratio:16/10;object-fit:cover;box-shadow:var(--shadow-lg)}
.hotel-img-row{display:grid;grid-template-columns:repeat(3,1fr);gap:.6rem}
.hotel-img-row img{width:100%;border-radius:10px;aspect-ratio:1;object-fit:cover;transition:.3s}
.hotel-img-row img:hover{transform:scale(1.03);box-shadow:var(--shadow)}
.hotel-badges{display:flex;flex-wrap:wrap;gap:.6rem;margin-bottom:2rem}
.hotel-badge{display:flex;align-items:center;gap:8px;padding:9px 18px;background:var(--bg2);border:1px solid var(--border);border-radius:30px;font-family:var(--accent);font-size:.72rem;color:var(--dark);letter-spacing:.5px}
.hotel-badge i{color:var(--saffron)}
.hotel-desc{color:var(--text-muted);font-size:.93rem;line-height:1.9;margin-bottom:2rem}

/* ─── FOOTER ─── */
.footer{background:var(--dark2);color:rgba(255,255,255,.7);padding:0}
.footer-top{border-bottom:1px solid rgba(255,255,255,.06);padding:3rem 4%;display:grid;grid-template-columns:1.5fr 1fr 1fr;gap:3rem;max-width:1200px;margin:0 auto}
.footer-brand .footer-logo-text{font-family:var(--accent);font-size:1.25rem;font-weight:700;letter-spacing:2px;color:#fff}
.footer-brand .footer-logo-text em{color:var(--saffron);font-style:normal}
.footer-tagline-main{font-size:.92rem;color:rgba(255,255,255,.7);margin-top:.5rem;line-height:1.6;font-weight:400}
.footer-tagline-sub{font-size:.78rem;color:rgba(255,255,255,.35);margin-bottom:1rem;letter-spacing:.5px}
.google-review-btn{display:inline-flex;align-items:center;gap:10px;background:#fff;color:#3c4043;text-decoration:none;padding:10px 18px;border-radius:30px;font-family:var(--accent);font-size:.78rem;font-weight:600;letter-spacing:.3px;margin-bottom:1.2rem;transition:.3s;box-shadow:0 2px 10px rgba(0,0,0,.2)}
.google-review-btn:hover{transform:translateY(-2px);box-shadow:0 4px 16px rgba(0,0,0,.3)}
.footer-col h5{font-family:var(--accent);font-size:.75rem;letter-spacing:3px;text-transform:uppercase;color:var(--saffron);margin-bottom:1rem}
.footer-col a{display:block;text-decoration:none;color:rgba(255,255,255,.45);font-size:.82rem;font-family:var(--accent);letter-spacing:.5px;margin-bottom:.5rem;transition:.3s}
.footer-col a:hover{color:var(--saffron-light)}
.footer-col p{font-size:.82rem;color:rgba(255,255,255,.45);margin-bottom:.4rem}
.footer-socials-row{display:flex;gap:.5rem;flex-wrap:wrap;margin-top:1rem}
.footer-socials-row a{width:36px;height:36px;border-radius:10px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.06);display:flex;align-items:center;justify-content:center;text-decoration:none;color:rgba(255,255,255,.4);font-size:.9rem;transition:.3s}
.footer-socials-row a:hover{color:var(--saffron-light);border-color:rgba(232,160,32,.3);background:rgba(232,160,32,.08)}
.footer-bottom{padding:1.2rem 4%;display:flex;align-items:center;justify-content:space-between;max-width:1200px;margin:0 auto}
.footer-bottom p{font-size:.72rem;color:rgba(255,255,255,.3);font-family:var(--accent)}
.footer-bottom .heart{color:#c0392b}

.hero-location{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);color:rgba(255,255,255,.9);padding:10px 20px;border-radius:30px;font-size:.88rem;font-weight:400;margin-bottom:2rem;backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);opacity:0;animation:fadeUp .8s .7s forwards;letter-spacing:.3px}
.hero-location svg{width:16px;height:16px;stroke:var(--saffron);flex-shrink:0}

/* ─── ANIMATIONS ─── */
@keyframes fadeUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes pulse{0%,100%{opacity:1;height:32px}50%{opacity:.3;height:18px}}
@keyframes scroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.reveal{opacity:0;transform:translateY(28px);transition:all .55s cubic-bezier(.16,1,.3,1)}
.reveal.vis{opacity:1;transform:translateY(0)}

/* ─── RESPONSIVE ─── */
@media(max-width:1024px){
  .menu-grid{grid-template-columns:1fr 1fr}
  .hotel-grid{grid-template-columns:1fr}
  .about-grid{grid-template-columns:1fr;gap:2.5rem}
  .about-img{max-height:400px;aspect-ratio:16/10}
  .gallery-grid{grid-template-columns:repeat(3,1fr)}
  .footer-top{grid-template-columns:1fr}
  .mission-pillars{gap:1rem}
}
@media(max-width:900px){
  .nav-center,.nav-right{display:none}
  .hamburger{display:flex}
  .mobile-nav{display:flex}
  .contact-grid{grid-template-columns:1fr}
  .top-bar-left{display:none}
}
@media(max-width:600px){
  section{padding:4rem 1.2rem}
  .hero{padding-bottom:4rem;min-height:100svh;padding-top:0}
  .hero-content{padding:0 1.4rem}
  .hero-label{font-size:.68rem;letter-spacing:3px}
  .hero h1{font-size:clamp(3rem,14vw,5rem);letter-spacing:-1px}
  .hero-desc{font-size:.95rem}
  .hero-location{font-size:.78rem;padding:8px 14px}
  .hero-actions{gap:.8rem}
  .btn-main,.btn-ghost{padding:12px 24px;font-size:.72rem}
  .top-bar{display:none}
  .nav{top:0;padding:14px 20px}
  .nav.scrolled{padding:12px 20px}
  .nav-cta{padding:8px 14px;font-size:.6rem;letter-spacing:.5px}
  .marquee-item{font-size:.85rem}
  .menu-grid{grid-template-columns:1fr}
  .gallery-grid{grid-template-columns:repeat(2,1fr);gap:5px;padding:5px}
  .owner-card{flex-direction:column;text-align:center;padding:1.8rem 1.2rem}
  .owner-initials{margin:0 auto}
  .footer-top{grid-template-columns:1fr;gap:2rem;padding:2.5rem 1.5rem}
  .footer-bottom{flex-direction:column;gap:.5rem;text-align:center;padding:1rem 1.5rem}
  .mission-pillars{gap:.7rem}
  .mission-pillar{padding:9px 16px;font-size:.75rem}
  .contact-grid{grid-template-columns:1fr}
  .contact-map{min-height:280px}
  .menu-tabs{gap:.4rem}
  .tab-btn{padding:7px 14px;font-size:.72rem;letter-spacing:1px}
  .delivery-pill{padding:8px 16px;font-size:.72rem}
  .hero-scroll{display:none}
  .about-grid{grid-template-columns:1fr;gap:2rem}
  .about-img{aspect-ratio:16/9}
  .values{grid-template-columns:1fr}
  .photo-break{height:auto;min-height:320px;padding:3rem 1rem}
  .photo-break-text blockquote{font-size:1.4rem}
  .section-title{font-size:clamp(2rem,8vw,2.8rem)}
}
